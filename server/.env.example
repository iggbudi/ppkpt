# SafeSphere Environment Configuration

# === REQUIRED FOR PRODUCTION ===

# Admin credentials (REQUIRED for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Session secret (REQUIRED for production, must be strong random string)
SESSION_SECRET=your-random-session-secret-at-least-32-chars

# === OPTIONAL ===

# Server configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Database path (optional, defaults to ./data/safesphere.db)
# DATABASE_PATH=./data/safesphere.db

# Retention settings (days)
RETENTION_DAYS=90
RETENTION_AUDIT_DAYS=365

# Chat rate limiting
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=60

# Report rate limiting
REPORT_RATE_LIMIT_WINDOW_MS=600000
REPORT_RATE_LIMIT_MAX=10

# MiMo AI configuration
MIMO_API_KEY=your-mimo-api-key
MIMO_MODEL=mimo-v2.5

# Backup settings (future)
# BACKUP_INTERVAL_HOURS=24
# BACKUP_MAX_COUNT=7
# BACKUP_ENCRYPTION_KEY=your-backup-encryption-key

# Evidence storage settings
EVIDENCE_UPLOADS_ENABLED=true
EVIDENCE_STORAGE_DRIVER=local
EVIDENCE_SCANNER_MODE=standard
# EVIDENCE_STORAGE_PATH=./data/evidence
# EVIDENCE_QUARANTINE_PATH=./data/quarantine
# EVIDENCE_TEMP_PATH=./data/temp-uploads
# EVIDENCE_BACKUP_PATH=./data/evidence-backups
# EVIDENCE_SCAN_QUEUE_INTERVAL_MS=30000
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310

# S3-Compatible Storage (Production)
# S3_REGION=auto
# S3_ENDPOINT=https://your-s3-endpoint.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=safesphere-evidence
# S3_FORCE_PATH_STYLE=false

# Evidence Encryption (Production)
# EVIDENCE_ENCRYPTION_ENABLED=true
# EVIDENCE_ENCRYPTION_KEY=your-encryption-key-min-32-chars

# === NOTES ===

# For development:
#   - NODE_ENV=development
#   - Demo user (demo/demo123) is auto-created
#   - Seed/reset endpoints are available

# For production:
#   - NODE_ENV=production
#   - ADMIN_USERNAME and ADMIN_PASSWORD are REQUIRED
#   - SESSION_SECRET is REQUIRED (must be different from default)
#   - Seed/reset endpoints are DISABLED
#   - Cookies use Secure flag
#   - Trust proxy is enabled
#   - Database migrations run automatically
#   - Retention cleanup runs at startup

# For testing:
#   - NODE_ENV=test
#   - Uses in-memory database by default
#   - Retention cleanup is disabled
#   - Demo user is auto-created

# === ADMIN ENDPOINTS ===

# GET  /api/admin/status      - System status & database health
# POST /api/admin/optimize    - Optimize database
# GET  /api/backup            - Create backup (query: includeAudit, encrypt, key)
# POST /api/restore           - Restore from backup
# GET  /api/admin/pending-deletions  - List pending deletion requests
# GET  /api/admin/legal-holds  - List active legal holds
NODE_ENV=development
TRUST_PROXY=
