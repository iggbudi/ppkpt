# SafeSphere chat backend configuration
PORT=3000
HOST=127.0.0.1

# Xiaomi MiMo API credentials. Keep the real .env file private and never commit it.
MIMO_API_KEY=your_api_key_here

# Default client assumes an OpenAI-compatible chat completions API.
# Example shape: POST ${MIMO_BASE_URL}/chat/completions
MIMO_BASE_URL=https://api-provider-xiaomi.example/v1
MIMO_MODEL=mimo-v2.5

# Optional request timeout in milliseconds
MIMO_TIMEOUT_MS=20000

# Basic in-memory rate limit for POST /api/chat
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=60

# Data retention period in days (reports with status 'Selesai' and audit logs older than this are cleaned up on startup)
RETENTION_DAYS=90
